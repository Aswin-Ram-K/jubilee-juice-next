# =============================================================================
# Database
# =============================================================================
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/jubilee_dev

# =============================================================================
# Auth (NextAuth / Auth.js)
# =============================================================================
# Secret used to sign session tokens. Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here-change-in-production

# The canonical URL of your site (no trailing slash)
AUTH_URL=http://localhost:3000

# =============================================================================
# Stripe
# =============================================================================
# Server-side secret key — never expose this to the browser.
STRIPE_SECRET_KEY=sk_test_...

# Publishable key — safe to expose to the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret from Stripe dashboard or Stripe CLI.
# Used to verify incoming webhook events.
STRIPE_WEBHOOK_SECRET=whsec_...
