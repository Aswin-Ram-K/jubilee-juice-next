# =============================================================================
# Environment
# =============================================================================
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
# Set to "export" for static GitHub Pages build, leave empty for server mode
NEXT_OUTPUT=

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# Connection string — used by Prisma and Docker Compose
DATABASE_URL=postgresql://jubilee:changeme@localhost:5432/jubilee_juice

# Docker Compose database credentials (must match DATABASE_URL)
POSTGRES_USER=jubilee
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jubilee_juice

# =============================================================================
# Auth (NextAuth / Auth.js) — NOT YET INSTALLED
# =============================================================================
# Uncomment when next-auth is added to dependencies:
# AUTH_SECRET=your-secret-here  # Generate with: openssl rand -base64 32
# AUTH_URL=http://localhost:3000

# =============================================================================
# Stripe (test mode)
# =============================================================================
# Server-side secret key — never expose to the browser
STRIPE_SECRET_KEY=sk_test_placeholder
# Publishable key — safe for browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
# Webhook signing secret from Stripe CLI or dashboard
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# =============================================================================
# Docker Compose — pgAdmin (optional, dev tools)
# =============================================================================
PGADMIN_EMAIL=admin@jubileejuice.com
PGADMIN_PASSWORD=admin
